{{ 'escape-game.css' | asset_url | stylesheet_tag }}

<section class="escape-steps color-{{ section.settings.color_scheme }}" id="escape-steps-{{ section.id }}" style="padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;">
    <div class="escape-section-header fade-in-up">
      {% if section.settings.title != blank %}
        <h2 class="escape-section-header__title neon-text--{{ section.settings.title_color }}">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="escape-section-header__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
      <div class="escape-section-header__line" style="background:{% case section.settings.title_color %}{% when 'cyan' %}#00f0ff{% when 'magenta' %}#ff00ff{% when 'violet' %}#8b00ff{% when 'green' %}#00ff88{% endcase %};"></div>
    </div>

    <div class="escape-steps__grid">
      {% for block in section.blocks %}
        <div class="escape-step escape-step--{{ forloop.index }} fade-in-up delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="escape-step__number">{{ block.settings.step_icon | default: forloop.index }}</div>
          <h3 class="escape-step__title">{{ block.settings.title }}</h3>
          <p class="escape-step__description">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function(){
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) { if(entry.isIntersecting) entry.target.classList.add('is-visible'); });
  }, {threshold:0.1});
  document.querySelectorAll('#escape-steps-{{ section.id }} .fade-in-up').forEach(function(el) { observer.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Comment ça marche",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Comment ça marche ?" },
    { "type": "textarea", "id": "subtitle", "label": "Sous-titre", "default": "Une expérience simple à réserver, intense à vivre" },
    {
      "type": "select",
      "id": "title_color",
      "label": "Couleur néon",
      "options": [
        { "value": "cyan", "label": "Cyan" },
        { "value": "magenta", "label": "Magenta" },
        { "value": "violet", "label": "Violet" },
        { "value": "green", "label": "Vert" }
      ],
      "default": "green"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2" },
    { "type": "range", "id": "padding_top", "label": "Espacement haut", "min": 0, "max": 100, "step": 4, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Espacement bas", "min": 0, "max": 100, "step": 4, "default": 60 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        { "type": "text", "id": "step_icon", "label": "Icône ou numéro", "default": "1" },
        { "type": "text", "id": "title", "label": "Titre de l'étape", "default": "Réservez" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Choisissez votre salle et votre créneau en ligne en quelques clics." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comment ça marche",
      "blocks": [
        { "type": "step", "settings": { "step_icon": "📅", "title": "Réservez", "description": "Choisissez votre salle et votre créneau en ligne en quelques clics." }},
        { "type": "step", "settings": { "step_icon": "🧩", "title": "Jouez", "description": "Plongez dans l'aventure avec votre équipe. Fouillez, réfléchissez, collaborez !" }},
        { "type": "step", "settings": { "step_icon": "🏆", "title": "Évadez-vous", "description": "Résolvez toutes les énigmes avant la fin du temps imparti pour remporter la victoire !" }}
      ]
    }
  ]
}
{% endschema %}
