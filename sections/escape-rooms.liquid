{{ 'escape-game.css' | asset_url | stylesheet_tag }}

<section class="escape-rooms color-{{ section.settings.color_scheme }}" id="escape-rooms-{{ section.id }}">
  <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;">
    <div class="escape-section-header fade-in-up">
      {% if section.settings.title != blank %}
        <h2 class="escape-section-header__title neon-text--{{ section.settings.title_color }}">
          {{ section.settings.title }}
        </h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="escape-section-header__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
      <div class="escape-section-header__line" style="background: {% case section.settings.title_color %}{% when 'cyan' %}#00f0ff{% when 'magenta' %}#ff00ff{% when 'violet' %}#8b00ff{% when 'green' %}#00ff88{% endcase %};"></div>
    </div>

    <div class="escape-rooms__grid">
      {% for block in section.blocks %}
        <div class="escape-card fade-in-up delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="escape-card__image">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'escape-card__img' }}
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a0a2e,#0d0d2b);display:flex;align-items:center;justify-content:center;">
                <span style="font-size:3rem;">🔒</span>
              </div>
            {% endif %}
            {% if block.settings.difficulty > 0 %}
              <div style="position:absolute;top:12px;right:12px;background:rgba(10,10,26,0.85);padding:4px 10px;border-radius:20px;font-size:0.75rem;color:#ff6b35;border:1px solid rgba(255,107,53,0.25);">
                {% for i in (1..5) %}{% if i <= block.settings.difficulty %}★{% else %}☆{% endif %}{% endfor %}
              </div>
            {% endif %}
          </div>

          <div class="escape-card__body">
            {% if block.settings.title != blank %}
              <h3 class="escape-card__title">{{ block.settings.title }}</h3>
            {% endif %}

            <div class="escape-card__meta">
              {% if block.settings.duration != blank %}
                <span class="escape-card__meta-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00f0ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {{ block.settings.duration }}
                </span>
              {% endif %}
              {% if block.settings.players != blank %}
                <span class="escape-card__meta-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8b00ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  {{ block.settings.players }}
                </span>
              {% endif %}
              {% if block.settings.success_rate != blank %}
                <span class="escape-card__meta-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00ff88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  {{ block.settings.success_rate }}% réussite
                </span>
              {% endif %}
            </div>

            {% if block.settings.description != blank %}
              <p class="escape-card__description">{{ block.settings.description }}</p>
            {% endif %}

            <a href="{{ block.settings.link | default: '#' }}" class="escape-card__cta btn-neon" style="background:#8b00ff;color:#fff;">
              {{ block.settings.button_text | default: 'Réserver cette salle' }}
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #escape-rooms-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
</style>

<script>
  (function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) entry.target.classList.add('is-visible');
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('#escape-rooms-{{ section.id }} .fade-in-up').forEach(function(el) {
      observer.observe(el);
    });
  })();
</script>

{% schema %}
{
  "name": "Salles d'escape",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre de la section",
      "default": "Nos salles"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Choisissez votre aventure et tentez de vous échapper"
    },
    {
      "type": "select",
      "id": "title_color",
      "label": "Couleur néon du titre",
      "options": [
        { "value": "cyan", "label": "Cyan" },
        { "value": "magenta", "label": "Magenta" },
        { "value": "violet", "label": "Violet" },
        { "value": "green", "label": "Vert" }
      ],
      "default": "violet"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espacement haut",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espacement bas",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "room",
      "name": "Salle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de la salle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nom de la salle",
          "default": "Le Manoir Hanté"
        },
        {
          "type": "range",
          "id": "difficulty",
          "label": "Difficulté (étoiles)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 3
        },
        {
          "type": "text",
          "id": "duration",
          "label": "Durée",
          "default": "60 min"
        },
        {
          "type": "text",
          "id": "players",
          "label": "Nombre de joueurs",
          "default": "2-6 joueurs"
        },
        {
          "type": "text",
          "id": "success_rate",
          "label": "Taux de réussite (%)",
          "default": "35"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description courte",
          "default": "Piégés dans un manoir mystérieux, vous avez 60 minutes pour résoudre les énigmes et trouver la sortie avant que les esprits ne se réveillent..."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Texte du bouton",
          "default": "Réserver cette salle"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien vers la salle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Salles d'escape",
      "blocks": [
        {
          "type": "room",
          "settings": {
            "title": "Le Manoir Hanté",
            "difficulty": 3,
            "duration": "60 min",
            "players": "2-6 joueurs",
            "success_rate": "35",
            "description": "Piégés dans un manoir mystérieux, vous avez 60 minutes pour résoudre les énigmes et trouver la sortie avant que les esprits ne se réveillent..."
          }
        },
        {
          "type": "room",
          "settings": {
            "title": "Le Braquage",
            "difficulty": 4,
            "duration": "60 min",
            "players": "3-8 joueurs",
            "success_rate": "25",
            "description": "Le casse du siècle vous attend. Déjouez les systèmes de sécurité, trouvez le coffre et repartez avec le butin avant l'arrivée de la police..."
          }
        },
        {
          "type": "room",
          "settings": {
            "title": "Le Laboratoire Secret",
            "difficulty": 5,
            "duration": "75 min",
            "players": "2-5 joueurs",
            "success_rate": "15",
            "description": "Un scientifique fou a créé un virus mortel. Infiltrez son laboratoire, trouvez l'antidote et sauvez l'humanité en moins de 75 minutes..."
          }
        }
      ]
    }
  ]
}
{% endschema %}
